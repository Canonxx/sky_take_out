<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hubu.mapper.SetMealDishMapper">
<!--    List<Long> querySetMealIdByIds(List<Long> ids);-->
    <select id="querySetMealIdByIds">
        select setmeal_id
        from setmeal_dish
        where dish_id in
        <foreach collection="ids" item="id" close=")" open="(" separator=",">
            #{id}
        </foreach>
    </select>
<!--    void insert(SetMealDish setMealDish1);-->
    <insert id="insert" parameterType="com.hubu.entity.SetMealDish">
        insert into setmeal_dish(setmeal_id,dish_id,name,price,copies)
        values (#{setmealId},#{dishId},#{name},#{price},#{copies})
    </insert>
<!--    List<Long> queryDishIdBySetMealId(Long id);-->
    <select id="queryDishIdBySetMealId">
        select dish_id
        from setmeal_dish
        where setmeal_id = #{id}
    </select>
<!--    List<SetMealDish> queryBySetMealId(Long id);-->
    <select id="queryBySetMealId" resultType="com.hubu.entity.SetMealDish">
        select *
        from  setmeal_dish
        where setmeal_id = #{id}
    </select>
<!--    void deleteBySetMealId(Long id);-->
    <delete id="deleteBySetMealId">
        delete from setmeal_dish
        where setmeal_id = #{id}
    </delete>
</mapper>
